# Required for auth + cloud sync (Dashboard → Supabase project settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Optional: roadmap worker (leave unset to use local engine + Groq below)
VITE_ROADMAP_API_URL=http://localhost:8787/api/roadmap/generate

# Groq (OpenAI-compatible) — used for AI resource suggestions on roadmaps
VITE_GROQ_API_KEY=gsk_YOUR_GROQ_KEY
# Optional model override (default: llama-3.3-70b-versatile)
# VITE_GROQ_MODEL=llama-3.3-70b-versatile
